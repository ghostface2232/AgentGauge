<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Gauge.Views.PopoverWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- RootHost is transparent so the DesktopAcrylic backdrop shows through, and
         hit-testable so it can hold focus for ESC / light dismiss. It is the element
         we slide + fade on show. RootBorder is where we round corners if we ever
         switch from DWM rounding to the transparent-window + inner-border approach. -->
    <Grid x:Name="RootHost" Background="Transparent" IsTabStop="True">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" />
        </Grid.RenderTransform>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeInvoked" />
        </Grid.KeyboardAccelerators>

        <Border x:Name="RootBorder" Padding="20">
            <TextBlock
                Text="Gauge 팝오버 (자리표시자)"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource BodyStrongTextBlockStyle}" />
        </Border>
    </Grid>
</Window>
