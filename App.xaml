<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Gauge.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Usage-level colors as named resources (never hardcoded inline at the
                 use site). Chosen to read on both light/dark acrylic; if per-theme
                 tuning is wanted later, move these into ResourceDictionary.ThemeDictionaries. -->
            <SolidColorBrush x:Key="UsageOkBrush" Color="#2E9E4F" />
            <SolidColorBrush x:Key="UsageCautionBrush" Color="#E0A100" />
            <SolidColorBrush x:Key="UsageDangerBrush" Color="#D13438" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
